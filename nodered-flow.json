[
  {
    "id": "flow_gas_001",
    "type": "tab",
    "label": "Gas Sensor → InfluxDB",
    "disabled": false,
    "info": "Suscribe sensor/gas por MQTT y escribe en InfluxDB 2.x"
  },
  {
    "id": "mqtt_in_001",
    "type": "mqtt in",
    "z": "flow_gas_001",
    "name": "Leer sensor/gas",
    "topic": "sensor/gas",
    "qos": "0",
    "datatype": "auto",
    "broker": "mqtt_broker_001",
    "nl": false,
    "rap": false,
    "rh": 0,
    "inputs": 0,
    "x": 150,
    "y": 200,
    "wires": [["fn_parse_001"]]
  },
  {
    "id": "fn_parse_001",
    "type": "function",
    "z": "flow_gas_001",
    "name": "Parsear y formatear",
    "func": "// El payload llega como string (ej. \"542\")\nvar valor = parseFloat(msg.payload);\n\nif (isNaN(valor)) {\n    node.warn(\"Payload no numérico: \" + msg.payload);\n    return null;\n}\n\n// Formato para nodo InfluxDB Out (array de puntos)\nmsg.payload = [\n    {\n        measurement: \"gas_level\",\n        fields: {\n            value: valor\n        },\n        tags: {\n            sensor: \"mq135\",\n            device: \"nodemcu-v2\"\n        }\n    }\n];\n\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 360,
    "y": 200,
    "wires": [["influx_out_001", "debug_001"]]
  },
  {
    "id": "influx_out_001",
    "type": "influxdb out",
    "z": "flow_gas_001",
    "influxdb": "influx_server_001",
    "name": "Escribir en gas_data",
    "measurement": "gas_level",
    "precision": "",
    "retentionPolicy": "",
    "database": "gas_data",
    "retentionPolicyV1": "",
    "org": "myorg",
    "bucket": "gas_data",
    "x": 600,
    "y": 200,
    "wires": []
  },
